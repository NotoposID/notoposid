# Build stage
FROM golang:1.21-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o main cmd/api/main.go

# Production stage
FROM alpine:latest
WORKDIR /app
COPY --from=builder /app/main .
COPY .env.example .env
EXPOSE 8000
CMD ["./main"]
